# ── docsearch-ingestion — Variables d'environnement ──────────

# Elasticsearch (cluster déjà démarré, géré par docsearch-infra)
ES_HOST=http://es01:9200
# ES_INDEX / DEFAULT_SOURCE_SUBFOLDER : index et sous-dossier de la
# source par défaut ("documents") — voir sources_config.py. Les
# sources ajoutées ensuite (./manage.sh add-source) vivent dans le
# registre Redis, pas dans des variables d'environnement.
ES_INDEX=documents
DEFAULT_SOURCE_SUBFOLDER=documents
# Alias ES partagé par tous les index de toutes les sources — voir
# sources_config.py. Rarement besoin d'y toucher.
ES_SEARCH_ALIAS=docsearch-all

# Serveurs Tika (démarrés par docsearch-infra)
TIKA_SERVERS=http://tika1:9998,http://tika2:9998,http://tika3:9998,http://tika4:9998

# Kafka (KRaft, démarré par docsearch-infra)
KAFKA_BOOTSTRAP=kafka:9092

# Point de montage FIXE (identique dans tous les conteneurs) sous
# lequel vivent tous les sous-dossiers sources — voir sources_config.py.
# Un bind-mount Docker est fixé à la création du conteneur, donc TOUTES
# les sources vivent sous CE SEUL montage parent (voir docsearch-infra/
# .env.example : SOURCES_ROOT côté hôte).
SOURCES_MOUNT=/sources

# Watcher — intervalle de polling en secondes.
# inotify ne fonctionne pas sur CIFS/NFS : le watcher utilise le
# mode polling, compatible avec tous les types de montage.
WATCHER_POLL_INTERVAL=10

# Taille de lot du worker
WORKER_BATCH_SIZE=200
# Flush périodique du buffer bulk() même si WORKER_BATCH_SIZE n'est
# pas atteint (en secondes). Indispensable pour les petits volumes :
# sans cela, les documents extraits restent en mémoire sans jamais
# être écrits dans Elasticsearch si moins de WORKER_BATCH_SIZE
# fichiers sont traités entre deux redémarrages du worker.
WORKER_FLUSH_INTERVAL=10

# ── Archives (.zip, .tar.*, .7z) ──────────────────────────────
# Le contenu des archives est indexé automatiquement (chaque membre
# devient un document, avec les ACL héritées de l'archive elle-même).
# Protection contre les "zip bombs" et le "zip slip" :
ARCHIVE_MAX_FILES=5000
ARCHIVE_MAX_TOTAL_SIZE_MB=1000
# Profondeur maximale d'archives imbriquées (zip dans un zip, etc.)
ARCHIVE_MAX_DEPTH=1

# UID propriétaire de SOURCES_ROOT sur l'hôte (id -u)
DOCKER_UID=1000

# ── Types de fichiers (activation + taille max) ──────────────
# Configuration modifiable à chaud via Redis, sans redémarrage :
#   ./manage.sh set-filetype jpg --enabled true --max-size 5
#   ./manage.sh get-filetypes
# FILETYPE_CONFIG_CACHE_TTL : délai avant qu'un changement soit pris
# en compte par les conteneurs déjà démarrés (défaut 10s).
FILETYPE_CONFIG_CACHE_TTL=10

# ── Paramètres opérationnels (modifiables à chaud) ───────────
# Ces variables ne servent que de valeur de DEPART — une fois modifiés
# via './manage.sh set-config <clé> <valeur>', les réglages vivent
# dans Redis et ces variables ne servent plus que de repli si Redis
# est injoignable.
#   ./manage.sh set-config archive_max_depth 2
#   ./manage.sh set-config worker_flush_interval 5
#   ./manage.sh get-config
RUNTIME_CONFIG_CACHE_TTL=10

# ── Filtres de sous-dossiers (inclusion/exclusion, modifiables à chaud) ─
# Chaque source a ses propres filtres, indépendants.
#   ./manage.sh exclude-path finance/confidentiel finance
#   ./manage.sh include-path finance
#   ./manage.sh list-path-filters
PATHFILTER_CACHE_TTL=10

# ── Sources (registre dynamique, modifiable à chaud) ─────────
#   ./manage.sh add-source finance finance_docs --label Finance
#   ./manage.sh list-sources
#   ./manage.sh remove-source finance
SOURCES_CONFIG_CACHE_TTL=10
