# ── docsearch-ingestion — Variables d'environnement ──────────

# Elasticsearch (cluster déjà démarré, géré par docsearch-infra)
ES_HOST=http://es01:9200

# Serveurs Tika (démarrés par docsearch-infra)
TIKA_SERVERS=http://tika1:9998,http://tika2:9998,http://tika3:9998,http://tika4:9998

# Kafka (KRaft, démarré par docsearch-infra)
KAFKA_BOOTSTRAP=kafka:9092

# Dossier source des documents (monté en volume)
DOCS_FOLDER=/documents

# Watcher — intervalle de polling en secondes.
# inotify ne fonctionne pas sur CIFS/NFS : le watcher utilise le
# mode polling, compatible avec tous les types de montage.
WATCHER_POLL_INTERVAL=10

# Taille de lot du worker
WORKER_BATCH_SIZE=200

# UID propriétaire du volume /documents sur l'hôte (id -u)
DOCKER_UID=1000
